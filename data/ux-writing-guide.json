      "rules": [
        "존댓말(해요체)을 기본으로 사용해요",
        "기술 용어는 쉬운 말로 풀어서 설명해요",
        "사용자의 행동을 긍정적으로 안내해요",
        "불안감을 줄이고 다음 단계를 명확히 알려줘요",
        "이모지는 핵심 포인트에만 절제해서 사용해요"
      ]
    },
    "writingRules": [
      { "rule": "한 문장은 40자 이내로 작성", "example": "유심이 3일 내 배송돼요" },
